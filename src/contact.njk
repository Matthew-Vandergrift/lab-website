---
layout: layouts/page.njk
title: Contact
eyebrow: Get in Touch
lede: Contact information, office hours, and guidance for prospective students.
permalink: /contact/
---
<section class="section">
  <div class="contact-panel contact-panel--details contact-page-block">
    <h2>Contact</h2>
    <dl class="contact-dl">
      {% if site.contact.position %}
        <dt>Title</dt>
        <dd>{{ site.contact.position }}</dd>
      {% endif %}
      <dt>Email</dt>
      <dd>{{ site.contact.email }}</dd>
      <dt>Office</dt>
      <dd>{{ site.contact.office }}</dd>
      {% if site.contact.address %}
        <dt>Address</dt>
        <dd>{{ site.contact.address }}</dd>
      {% endif %}
    </dl>
  </div>
</section>

<section class="section">
  <h2>Prospective students</h2>
  <div class="card contact-page-block">
    {{ siteText.prospectiveStudents | markdown | safe }}
  </div>
</section>

<section class="section">
  <div class="contact-panel contact-page-block">
    <h2>Calendar</h2>
    <div class="calendar-embeds">
      {% for link in site.contact.calendarLinks %}
        <div class="calendar-embed">
          <iframe
            src="{{ link.url | withBaseUrl }}"
            title="{{ link.label }}"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
